# =============================================================================
# CANELO - Variables de entorno
# =============================================================================
# Uso local:
#   1. Copiar este archivo:  cp .env.example .env
#   2. Completar los valores reales en .env (nunca commitear .env)
#
# Vercel (Project Settings -> Environment Variables):
#   - DATABASE_URL, ADMIN_USER, ADMIN_PASSWORD, ADMIN_SESSION_SECRET (servidor)
#   - VITE_WHATSAPP_PHONE, VITE_SITE_URL, VITE_ENABLE_REMOTE_ADMIN_WRITES (build)
#   - Tras agregar o cambiar variables, hacer redeploy.
# =============================================================================

# --- Servidor (Express / Vercel Functions) ---

# PostgreSQL (Neon). Obligatoria.
DATABASE_URL=postgresql://usuario:password@ep-xxxx.neon.tech/neondb?sslmode=require

# Puerto del API en desarrollo (opcional, default 8787).
API_PORT=8787

# Panel admin: mismas credenciales que el modal "Ingresar admin".
# Solo servidor. No usar prefijo VITE_ (no van al bundle del navegador).
ADMIN_USER=tu-email@ejemplo.com
ADMIN_PASSWORD=cambiar_por_clave_segura

# Firma de tokens de sesion admin (12 h). Minimo ~32 caracteres aleatorios.
# Generar: openssl rand -base64 32
ADMIN_SESSION_SECRET=cambiar_por_string_largo_aleatorio

# --- Cliente (Vite - prefijo VITE_ obligatorio en build) ---

# WhatsApp: solo digitos, codigo de pais, sin +. Ej: 54911XXXXXXXX
VITE_WHATSAPP_PHONE=54911XXXXXXXX

# URL publica del sitio (canonical y Open Graph en produccion).
VITE_SITE_URL=https://tu-proyecto.vercel.app

# Escrituras del admin contra la API (omitir o true; false = solo lectura en UI).
VITE_ENABLE_REMOTE_ADMIN_WRITES=true
