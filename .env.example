# =============================================================================
# CANELO - Variables de entorno
# =============================================================================
# Uso local:
#   1. Copiar:  Copy-Item .env.example .env
#   2. Completar valores reales en .env (nunca commitear .env)
#
# Vercel (Settings -> Environment Variables):
#   Servidor: DATABASE_URL, ADMIN_USER, ADMIN_PASSWORD, ADMIN_SESSION_SECRET
#   Build:    VITE_WHATSAPP_PHONE, VITE_SITE_URL, VITE_ENABLE_REMOTE_ADMIN_WRITES
#   Nombre exacto: ADMIN_SESSION_SECRET (no DMIN_SESSION_SECRET).
#   Tras cambiar variables: Redeploy.
# =============================================================================

# --- Servidor (Express / Vercel Functions) ---

# PostgreSQL (Neon). Usar connection string POOLED (-pooler en el host).
DATABASE_URL=postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

API_PORT=8787

ADMIN_USER=tu-email@ejemplo.com
ADMIN_PASSWORD=cambiar_por_clave_segura

# Firma tokens admin (12 h). Generar en PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
ADMIN_SESSION_SECRET=cambiar_por_string_largo_aleatorio

# --- Cliente (Vite; prefijo VITE_ obligatorio) ---

# WhatsApp: solo digitos, codigo pais, sin +. Ej: 54911XXXXXXXX
VITE_WHATSAPP_PHONE=54911XXXXXXXX

VITE_SITE_URL=https://canelo.vercel.app

VITE_ENABLE_REMOTE_ADMIN_WRITES=true
