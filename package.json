{
  "name": "canelo",
  "version": "1.0.0",
  "private": true,
  "description": "Tienda dietetica con carrito y pedido por WhatsApp",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node --watch server/index.mjs\"",
    "dev:client": "vite",
    "dev:api": "node --watch server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start:api": "node server/index.mjs",
    "db:migrate": "node scripts/run-migration.mjs",
    "db:seed": "node scripts/seed-catalog.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "catalog:parse-pdf": "node scripts/parse-catalog-pdf.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "node --test server/**/*.test.mjs"
  },
  "keywords": [
    "dietetica",
    "react",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "pdf-parse": "^1.1.1",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
